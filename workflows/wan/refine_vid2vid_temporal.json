{
  "_meta": {
    "description": "Vid2Vid temporal refinement workflow - basic version",
    "version": "2.1",
    "changelog": "2025-12-23: Removed TemporalSmooth (node unavailable), using standard KSampler"
  },

  "video_loader": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "{{INPUT_VIDEO}}",
      "force_rate": 0,
      "force_size": "Disabled",
      "custom_width": 0,
      "custom_height": 0,
      "frame_load_cap": "{{TEMPORAL_WINDOW}}",
      "skip_first_frames": 0,
      "select_every_nth": 1
    }
  },

  "checkpoint_loader": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },

  "positive_prompt": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{POSITIVE_PROMPT}}",
      "clip": ["checkpoint_loader", 1]
    }
  },

  "negative_prompt": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{NEGATIVE_PROMPT}}",
      "clip": ["checkpoint_loader", 1]
    }
  },

  "vae_encode": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["video_loader", 0],
      "vae": ["checkpoint_loader", 2]
    }
  },

  "sampler": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{SEED}}",
      "control_after_generate": "fixed",
      "steps": "{{STEPS}}",
      "cfg": "{{CFG_SCALE}}",
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": "{{DENOISE_STRENGTH}}",
      "model": ["checkpoint_loader", 0],
      "positive": ["positive_prompt", 0],
      "negative": ["negative_prompt", 0],
      "latent_image": ["vae_encode", 0]
    }
  },

  "vae_decode": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["sampler", 0],
      "vae": ["checkpoint_loader", 2]
    }
  },

  "create_video": {
    "class_type": "CreateVideo",
    "inputs": {
      "fps": "{{FPS}}",
      "images": ["vae_decode", 0]
    }
  },

  "save_video": {
    "class_type": "SaveVideo",
    "inputs": {
      "filename_prefix": "continuum/refined_temporal",
      "format": "auto",
      "codec": "auto",
      "video": ["create_video", 0]
    }
  }
}

{
  "_comment": "WanFirstLastFrameToVideo test - keyframe identity conditioning for expression freedom",
  "_architecture_ref": "Lesson #77 - condition first/last frames, let middle interpolate naturally",
  
  "clip_loader": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "{{CLIP_MODEL}}",
      "type": "wan",
      "device": "default"
    }
  },
  "vae_loader": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "{{VAE_MODEL}}"
    }
  },
  "unet_loader": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "{{UNET_MODEL}}",
      "weight_dtype": "default"
    }
  },
  "clip_vision_loader": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "{{CLIP_VISION_MODEL}}"
    }
  },
  "model_sampling": {
    "class_type": "ModelSamplingSD3",
    "inputs": {
      "shift": 8,
      "model": [
        "unet_loader",
        0
      ]
    }
  },
  
  "_comment_inputs": "Separate loading: bridge frame for structure, face ref for identity",
  
  "load_init_image": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{INIT_IMAGE}}"
    }
  },
  "load_face_ref": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{FACE_REF_1}}"
    }
  },
  
  "_comment_encoding": "Encode face ref for BOTH start and end clip_vision (identity at keyframes only)",
  
  "clip_vision_encode_start": {
    "class_type": "CLIPVisionEncode",
    "inputs": {
      "crop": "none",
      "clip_vision": [
        "clip_vision_loader",
        0
      ],
      "image": [
        "load_face_ref",
        0
      ]
    }
  },
  "clip_vision_encode_end": {
    "class_type": "CLIPVisionEncode",
    "inputs": {
      "crop": "none",
      "clip_vision": [
        "clip_vision_loader",
        0
      ],
      "image": [
        "load_face_ref",
        0
      ]
    }
  },
  
  "positive_prompt": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{POSITIVE_PROMPT}}",
      "clip": [
        "clip_loader",
        0
      ]
    }
  },
  "negative_prompt": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{NEGATIVE_PROMPT}}",
      "clip": [
        "clip_loader",
        0
      ]
    }
  },
  
  "_comment_core": "WanFirstLastFrameToVideo: identity via clip_vision at keyframes, structure via start/end images",
  
  "wan_firstlast": {
    "class_type": "WanFirstLastFrameToVideo",
    "inputs": {
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "length": "{{FRAMES}}",
      "batch_size": 1,
      "positive": [
        "positive_prompt",
        0
      ],
      "negative": [
        "negative_prompt",
        0
      ],
      "vae": [
        "vae_loader",
        0
      ],
      "clip_vision_start_image": [
        "clip_vision_encode_start",
        0
      ],
      "clip_vision_end_image": [
        "clip_vision_encode_end",
        0
      ],
      "start_image": [
        "load_init_image",
        0
      ],
      "end_image": [
        "load_init_image",
        0
      ]
    }
  },
  
  "sampler": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{SEED}}",
      "control_after_generate": "fixed",
      "steps": "{{STEPS}}",
      "cfg": "{{CFG_SCALE}}",
      "sampler_name": "uni_pc",
      "scheduler": "simple",
      "denoise": 1,
      "model": [
        "model_sampling",
        0
      ],
      "positive": [
        "wan_firstlast",
        0
      ],
      "negative": [
        "wan_firstlast",
        1
      ],
      "latent_image": [
        "wan_firstlast",
        2
      ]
    }
  },
  "vae_decode": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": [
        "sampler",
        0
      ],
      "vae": [
        "vae_loader",
        0
      ]
    }
  },
  "create_video": {
    "class_type": "CreateVideo",
    "inputs": {
      "fps": "{{FPS}}",
      "images": [
        "vae_decode",
        0
      ]
    }
  },
  "save_video": {
    "class_type": "SaveVideo",
    "inputs": {
      "filename_prefix": "continuum/i2v_firstlast",
      "format": "auto",
      "codec": "auto",
      "video": [
        "create_video",
        0
      ]
    }
  }
}
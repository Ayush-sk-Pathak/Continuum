{
  "video_loader": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "{{INPUT_VIDEO}}",
      "force_rate": 0,
      "force_size": "Disabled",
      "custom_width": 0,
      "custom_height": 0,
      "frame_load_cap": 0,
      "skip_first_frames": 0,
      "select_every_nth": 1
    }
  },

  "rife_interpolate": {
    "class_type": "RIFE VFI",
    "inputs": {
      "ckpt_name": "rife47.pth",
      "frames": ["video_loader", 0],
      "multiplier": "{{MULTIPLIER}}",
      "fast_mode": true,
      "ensemble": false,
      "scale_factor": 1.0,
      "clear_cache_after_n_frames": 10
    }
  },

  "video_combine": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["rife_interpolate", 0],
      "frame_rate": "{{TARGET_FPS}}",
      "loop_count": 0,
      "filename_prefix": "continuum/interpolated",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true,
      "audio": ["video_loader", 2]
    }
  }
}
{
  "load_image": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{SOURCE_IMAGE}}"
    }
  },

  "pose_detector": {
    "class_type": "DWPreprocessor",
    "inputs": {
      "detect_hand": "enable",
      "detect_body": "enable", 
      "detect_face": "enable",
      "resolution": 1024,
      "bbox_detector": "yolox_l.onnx",
      "pose_estimator": "dw-ll_ucoco_384_bs5.torchscript.pt",
      "image": ["load_image", 0]
    }
  },

  "save_image": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "continuum/pose",
      "images": ["pose_detector", 0]
    }
  }
}
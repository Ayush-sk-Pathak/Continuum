  "_quality_tiers": {
    "1": "Development - fast iteration, lower quality",
    "2": "Production - balanced quality/performance", 
    "3": "Demo/Pilot - maximum quality for presentations"
  },

  "_usage": {
    "python_example": "model_config = load_models_json()['wan21']['t2v']['beast']",
    "env_override": "CONTINUUM_MODEL_TIER=beast (overrides default 'dev')"
  }
}
        "clip_vision": "clip_vision_h.safetensors",
        "vram_required_gb": 16,
        "max_resolution": "480p",
        "quality_tier": 1
      },
      "standard": {
        "_description": "Production - 720p output",
        "unet": "wan2.1_i2v_720p_14B_bf16.safetensors",
        "vae": "wan_2.1_vae.safetensors",
        "clip": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
        "clip_vision": "clip_vision_h.safetensors",
        "vram_required_gb": 24,
        "max_resolution": "720p",
        "quality_tier": 2
      },
      "beast": {
        "_description": "Demo/pilot - maximum quality",
        "unet": "wan2.1_i2v_720p_14B_fp16.safetensors",
        "vae": "wan_2.1_vae.safetensors",
        "clip": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
        "clip_vision": "clip_vision_h.safetensors",
        "vram_required_gb": 40,
        "max_resolution": "1080p",
        "quality_tier": 3
      }
    }
